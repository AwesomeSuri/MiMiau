# Copy to backend/php/.env (gitignored).
#
# Docker Compose loads this via env_file. DB_* and FRONTEND_URL are overridden
# in docker-compose.yml — do not duplicate them here when using Docker.

# Required — Make.com webhook for verification & password-reset emails.
# For local testing, use a free URL from https://webhook.site
MAKE_WEBHOOK=https://hook.eu1.make.com/your-webhook-id

# --- Only when running PHP on the host (not via Docker) ---
# DB_HOST=127.0.0.1
# DB_NAME=mimiau
# DB_USER=root
# DB_PASS=miaupassword
# FRONTEND_URL=http://localhost:8000/index.html
